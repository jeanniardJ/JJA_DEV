{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <!-- Section À propos -->
    <section id="about" class="py-5 bg-light-custom">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <h2 class="display-5 fw-bold mb-4 text-primary-custom">
                        À propos de JJA DEV
                    </h2>
                    <p class="lead text-secondary-custom">JJA DEV est mon laboratoire personnel de développement et d'expérimentation technologique. 
                    Cette plateforme me permet de :</p>
                    <ul class="list-unstyled mt-4">
                        <li class="d-flex align-items-center mb-3">
                            <div class="badge bg-primary-custom rounded-pill me-3">
                                <i class="fas fa-check"></i>
                            </div>
                            <span class="text-secondary-custom">Gérer mes projets de développement</span>
                        </li>
                        <li class="d-flex align-items-center mb-3">
                            <div class="badge bg-primary-custom rounded-pill me-3">
                                <i class="fas fa-check"></i>
                            </div>
                            <span class="text-secondary-custom">Expérimenter avec de nouvelles technologies</span>
                        </li>
                        <li class="d-flex align-items-center mb-3">
                            <div class="badge bg-primary-custom rounded-pill me-3">
                                <i class="fas fa-check"></i>
                            </div>
                            <span class="text-secondary-custom">Suivre l'évolution de mes compétences</span>
                        </li>
                        <li class="d-flex align-items-center mb-3">
                            <div class="badge bg-primary-custom rounded-pill me-3">
                                <i class="fas fa-check"></i>
                            </div>
                            <span class="text-secondary-custom">Centraliser mes outils de développement</span>
                        </li>
                    </ul>
                    <a href="https://github.com/JJA-DEV" target="_blank" class="btn btn-primary-custom btn-lg">
                        <i class="fab fa-github me-2"></i>Voir mes projets GitHub
                    </a>
                </div>
                <div class="col-lg-6">
                    <div class="row g-4">                        <div class="col-6">
                            <div class="card text-center border-0 shadow-sm h-100 card-custom">
                                <div class="card-body p-4">
                                    <div class="text-primary-custom mb-3">
                                        <i class="fas fa-code fa-2x"></i>
                                    </div>
                                    <h3 class="card-title h2 mb-2 text-dark-custom">50+</h3>
                                    <p class="card-text text-muted">Projets développés</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="card text-center border-0 shadow-sm h-100 card-custom">
                                <div class="card-body p-4">
                                    <div class="text-primary-custom mb-3">
                                        <i class="fas fa-cogs fa-2x"></i>
                                    </div>
                                    <h3 class="card-title h2 mb-2 text-dark-custom">15+</h3>
                                    <p class="card-text text-muted">Technologies maîtrisées</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="card text-center border-0 shadow-sm h-100 card-custom">
                                <div class="card-body p-4">
                                    <div class="text-primary-custom mb-3">
                                        <i class="fas fa-calendar-alt fa-2x"></i>
                                    </div>
                                    <h3 class="card-title h2 mb-2 text-dark-custom">3+</h3>
                                    <p class="card-text text-muted">Années d'expérience</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="card text-center border-0 shadow-sm h-100 card-custom">
                                <div class="card-body p-4">
                                    <div class="text-accent-custom mb-3">
                                        <i class="fas fa-server fa-2x"></i>
                                    </div>
                                    <h3 class="card-title h2 mb-2 text-dark-custom">99%</h3>
                                    <p class="card-text text-muted">Uptime CRM</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section Technologies -->
    <section id="technologies" class="py-5">
        <div class="container">            <div class="text-center mb-5">
                <h2 class="display-5 fw-bold text-primary-custom">Technologies & Compétences</h2>
                <p class="lead text-secondary-custom">
                    Les outils et technologies que j'utilise dans mes projets
                </p>
            </div>
            
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm card-custom">
                        <div class="card-body p-4 text-center">
                            <div class="text-primary-custom mb-3">
                                <i class="fab fa-php fa-3x"></i>
                            </div>
                            <h4 class="card-title text-dark-custom">Backend</h4>
                            <p class="text-muted mb-3">PHP, Symfony, MySQL, Docker</p>
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar bg-primary-custom" role="progressbar" style="width: 90%" aria-valuenow="90" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <span class="badge bg-primary-custom text-white">Expert</span>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm card-custom">
                        <div class="card-body p-4 text-center">
                            <div class="text-accent-custom mb-3">
                                <i class="fab fa-react fa-3x"></i>
                            </div>
                            <h4 class="card-title text-dark-custom">Frontend</h4>
                            <p class="text-muted mb-3">JavaScript, React, Bootstrap, SASS</p>
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar bg-accent-custom" role="progressbar" style="width: 85%" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <span class="badge bg-accent-custom text-dark">Avancé</span>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm card-custom">
                        <div class="card-body p-4 text-center">
                            <div class="text-dark-custom mb-3">
                                <i class="fas fa-tools fa-3x"></i>
                            </div>
                            <h4 class="card-title text-dark-custom">DevOps</h4>
                            <p class="text-muted mb-3">Git, GitHub Actions, OVH, CI/CD</p>
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar bg-dark-custom" role="progressbar" style="width: 75%" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>                            <span class="badge bg-dark-custom text-white">Intermédiaire</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section Call-to-Action Contact -->
    <section id="contact" class="py-5 bg-primary-custom text-white">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h2 class="display-5 fw-bold mb-4">Restons en contact</h2>
                    <p class="lead mb-5">
                        Vous avez une question ou souhaitez collaborer sur un projet ?
                    </p>
                    
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                        <a href="{{ path('app_contact') }}" class="btn btn-light-custom btn-lg">
                            <i class="fas fa-envelope me-2"></i>Me contacter
                        </a>
                        <a href="https://github.com/JJA-DEV" target="_blank" class="btn btn-outline-light-custom btn-lg">
                            <i class="fab fa-github me-2"></i>GitHub
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}