            <li class="nav-item" role="presentation">
                <a class="nav-link active fw-bold" id="backend-tab" data-bs-toggle="tab" data-bs-target="#backend"
                    href="#" role="tab" aria-controls="backend" aria-selected="true">
                    Backend
                </a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link fw-bold" id="frontend-tab" data-bs-toggle="tab" data-bs-target="#frontend" href="#"
                    role="tab" aria-controls="frontend" aria-selected="false">
                    Frontend
                </a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link fw-bold" id="devops-tab" data-bs-toggle="tab" data-bs-target="#devops" href="#"
                    role="tab" aria-controls="devops" aria-selected="false">
                    DevOps
                </a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link fw-bold" id="security-tab" data-bs-toggle="tab" data-bs-target="#security" href="#"
