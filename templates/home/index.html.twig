                </a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link fw-bold" id="tools-tab" data-bs-toggle="tab" data-bs-target="#tools" href="#"
                    role="tab" aria-controls="tools" aria-selected="false">
                    Outils
                </a>
            </li>
        </ul>

        <!-- Contenu des onglets -->
        <div class="tab-content" id="stackTabsContent">
            <!-- Onglet Backend -->
            <div class="tab-pane fade show active" id="backend" role="tabpanel" aria-labelledby="backend-tab">
                <div class="row g-4">
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-filetype-php stack-icon text-primary me-3" aria-label="PHP"
                                    title="PHP"></i>
                                <span class="fw-bold">PHP</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-box stack-icon text-success me-3" aria-label="Symfony"
                                    title="Symfony"></i>
                                <span class="fw-bold">Symfony</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-database stack-icon text-info me-3" aria-label="MySQL"
                                    title="MySQL"></i>
                                <span class="fw-bold">MySQL</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-wordpress stack-icon text-primary me-3" aria-label="WordPress"
                                    title="WordPress"></i>
                                <span class="fw-bold">WordPress</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Onglet Frontend -->
            <div class="tab-pane fade" id="frontend" role="tabpanel" aria-labelledby="frontend-tab">
                <div class="row g-4">
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-filetype-html stack-icon text-danger me-3" aria-label="HTML5"
                                    title="HTML5"></i>
                                <span class="fw-bold">HTML5</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-filetype-css stack-icon text-primary me-3" aria-label="CSS3"
                                    title="CSS3"></i>
                                <span class="fw-bold">CSS3</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-filetype-js stack-icon text-warning me-3" aria-label="JavaScript"
                                    title="JavaScript"></i>
                                <span class="fw-bold">JavaScript</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-bootstrap-fill stack-icon text-purple me-3" aria-label="Bootstrap"
                                    title="Bootstrap"></i>
                                <span class="fw-bold">Bootstrap</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Onglet DevOps -->
            <div class="tab-pane fade" id="devops" role="tabpanel" aria-labelledby="devops-tab">
                <div class="row g-4">
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-git stack-icon text-danger me-3" aria-label="Git" title="Git"></i>
                                <span class="fw-bold">Git</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-github stack-icon text-dark me-3" aria-label="GitHub Actions"
                                    title="GitHub Actions"></i>
                                <span class="fw-bold">GitHub Actions</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-box-seam stack-icon text-info me-3" aria-label="Docker"
                                    title="Docker"></i>
                                <span class="fw-bold">Docker</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-cloud stack-icon text-primary me-3" aria-label="OVH Cloud"
                                    title="OVH Cloud"></i>
                                <span class="fw-bold">OVH Cloud</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Onglet Sécurité -->
            <div class="tab-pane fade" id="security" role="tabpanel" aria-labelledby="security-tab">
                <div class="row g-4">
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-shield-check stack-icon text-primary me-3" aria-label="Sécurité"
                                    title="Sécurité"></i>
                                <span class="fw-bold">Sécurité</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-lock stack-icon text-secondary me-3" aria-label="Authentification"
                                    title="Authentification"></i>
                                <span class="fw-bold">Authentification</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-key stack-icon text-warning me-3" aria-label="Chiffrement"
                                    title="Chiffrement"></i>
                                <span class="fw-bold">Chiffrement</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-shield-lock stack-icon text-info me-3" aria-label="Outils Sécurité"
                                    title="Outils Sécurité"></i>
                                <span class="fw-bold">Outils Sécurité</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-person-check stack-icon text-success me-3" aria-label="Contrôle d'accès"
                                    title="Contrôle d'accès"></i>
                                <span class="fw-bold">Contrôle d'accès</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Onglet Outils -->
            <div class="tab-pane fade" id="tools" role="tabpanel" aria-labelledby="tools-tab">
                <div class="row g-4">
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-gear stack-icon text-primary me-3" aria-label="Build" title="Build"></i>
                                <span class="fw-bold">Build</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-wrench stack-icon text-secondary me-3" aria-label="Configuration"
                                    title="Configuration"></i>
                                <span class="fw-bold">Configuration</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-bug stack-icon text-danger me-3" aria-label="Tests" title="Tests"></i>
                                <span class="fw-bold">Tests</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-cloud-arrow-up stack-icon text-success me-3" aria-label="Déploiement"
                                    title="Déploiement"></i>
                                <span class="fw-bold">Déploiement</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card border-0 shadow-sm card-stack-height">
                            <div class="card-body d-flex align-items-center">
                                <i class="bi bi-terminal stack-icon text-dark me-3" aria-label="CLI" title="CLI"></i>
                                <span class="fw-bold">CLI</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section Modules -->
<section id="modules" class="py-5 bg-dark-custom">
    <div class="container">
        <div class="text-left">
            <h3 class="fw-bold text-white mb-3">Modules</h3>
        </div>
        <div class="row">
            <div class="col-12 col-lg-3">
                <div class="module-card text-center">
                    <img src="{{ asset('images/modules/symfony.png') }}" alt="Symfony Projects" />
                    <h5 class="fw-bold mb-3">Symfony Projects</h5>
                    <p>
                        Collection de projets Symfony avec CRM, CMS et solutions e-commerce
                    </p>
                </div>
            </div>
            <div class="col-12 col-lg-3">
                <div class="module-card text-center">
                    <img src="{{ asset('images/modules/security.png') }}" alt="Security Scans" />
                    <h5 class="fw-bold mb-3">Security Scans</h5>
                    <p>
                        Outils d'analyse et de sécurisation des applications web
                    </p>
                </div>
            </div>
            <div class="col-12 col-lg-3">
                <div class="module-card text-center">
                    <img src="{{ asset('images/modules/automation.png') }}" alt="Automation Scripts" />
                    <h5 class="fw-bold mb-3">Automation Scripts</h5>
                    <p>
                        Scripts d'automatisation pour le déploiement et la maintenance
                    </p>
                </div>
            </div>
            <div class="col-12 col-lg-3">
                <div class="module-card text-center">
                    <img src="{{ asset('images/modules/notes.png') }}" alt="Technical Notes" />
                    <h5 class="fw-bold mb-3">Technical Notes</h5>
                    <p>
                        Documentation technique et guides de bonnes pratiques
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section Roadmap -->
<section id="roadmap" class="py-5 bg-light-custom">
    <div class="container">
        <div class="text-left mb-5">
            <h3 class="fw-bold text-white mb-3">Roadmap</h3>
        </div>

        <div class="row">
            <div class="col-lg-12 mx-auto">
                <div class="roadmap-container custom-scroll">
                    <!-- Ticket 1 -->
                    <div class="roadmap-item d-flex">
                        <div class="roadmap-bar d-flex align-items-center justify-content-center">
                            <i class="bi bi-calendar3"></i>
                        </div>
                        <div class="roadmap-content flex-grow-1 ms-5">
                            <div class="d-flex justify-content-between align-items-start">
                                <h6 class="fw-bold mb-0">Implémentation du module CRM avancé</h6>
                            </div>
                            <p class="mb-2">
                                Développement d'un système CRM complet avec gestion des prospects, devis et facturation.
                            </p>
                        </div>
                    </div>

                    <!-- Ticket 2 -->
                    <div class="roadmap-item d-flex">
                        <div class="roadmap-bar d-flex align-items-center justify-content-center">
                            <i class="bi bi-calendar3"></i>
                        </div>
                        <div class="roadmap-content flex-grow-1 ms-5">
                            <div class="d-flex justify-content-between align-items-start">
                                <h6 class="fw-bold mb-0">Migration vers Symfony 7.0</h6>
                            </div>
                            <p class="mb-2">
                                Mise à jour de tous les projets vers la dernière version LTS de Symfony.
                            </p>
                        </div>
                    </div>

                    <!-- Ticket 3 -->
                    <div class="roadmap-item d-flex">
                        <div class="roadmap-bar d-flex align-items-center justify-content-center">
                            <i class="bi bi-calendar3"></i>
                        </div>
                        <div class="roadmap-content flex-grow-1 ms-5">
                            <div class="d-flex justify-content-between align-items-start">
                                <h6 class="fw-bold mb-0">API REST complète pour le CMS</h6>
                            </div>
                            <p class="mb-2">
                                Création d'une API REST complète pour l'administration et la gestion de contenu.
                            </p>
                        </div>
                    </div>

                    <!-- Ticket 4 (visible après scroll) -->
                    <div class="roadmap-item d-flex">
                        <div class="roadmap-bar">
                            <i class="bi bi-calendar3"></i>
                        </div>
                        <div class="roadmap-content flex-grow-1 ms-5">
                            <div class="d-flex justify-content-between align-items-start">
                                <h6 class="fw-bold mb-0">Interface React pour l'administration</h6>
                            </div>
                            <p class="mb-2">
                                Développement d'une interface React moderne pour l'administration des projets.
                            </p>
                        </div>
                    </div>

                    <!-- Ticket 5 (visible après scroll) -->
                    <div class="roadmap-item d-flex">
                        <div class="roadmap-bar">
                            <i class="bi bi-calendar3"></i>
                        </div>
                        <div class="roadmap-content flex-grow-1 ms-5">
                            <div class="d-flex justify-content-between align-items-start">
                                <h6 class="fw-bold mb-0">Optimisation performance et cache</h6>
                            </div>
                            <p class="mb-2">
                                Implémentation de systèmes de cache avancés et optimisation des performances.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section Latest GitHub Commits -->
<section id="github-commits" class="py-5 bg-dark-custom">
    <div class="container">
        <div class="text-left mb-5">
            <h3 class="fw-bold text-white mb-3">Latest GitHub Commits</h3>
        </div>
        <div class="row">
            <div class="col-lg-10 mx-auto">
                <div class="commits-container custom-scroll">
                    {% for commit in commits|slice(0,10) %}
                    <div class="commit-item">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-2">{{ commit.message }}</h6>
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <span class="commit-author">
                                        <i class="fas fa-user me-1"></i>{{ commit.author }}
                                    </span>
                                    <span class="commit-date">
                                        <i class="fas fa-clock me-1"></i>{{ commit.date }}
                                    </span>
                                </div>
                                <p class="mb-0">
                                    {{ commit.description }}
                                </p>
                            </div>
                            <span class="commit-hash">{{ commit.hash }}</span>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section Contact (uniformisée) -->
<section id="contact" class="py-5 bg-dark-tertiary position-relative">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="text-left mb-4 mb-md-5">
                    <h3 class="fw-bold text-white mb-3">
                        Restons en contact
                    </h3>
                    <p class="lead text-white mb-4 mb-md-5">
                        Vous avez une question ou souhaitez collaborer sur un projet ? N'hésitez pas à me contacter
                        !
                    </p>
                </div>
                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                    <a href="{{ path('app_contact') }}" class="btn btn-teal-primary btn-lg px-4">
                        <i class="bi bi-envelope-paper-fill me-2"></i>Me contacter
                    </a>
                    <a href="https://github.com/jeanniardJ" target="_blank"
                        class="btn btn-outline-light-custom btn-lg px-4">
                        <i class="bi bi-github me-2"></i>GitHub
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
