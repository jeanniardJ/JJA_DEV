{% extends 'base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
{{ encore_entry_link_tags('home') }}
{% endblock %}

{% block body %}
<!-- Section À propos -->
<section id="about" class="py-5 bg-light-custom mt-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-4 col-md-5 text-center">
                <div class="avatar-container mb-4">
                    <img src="{{ asset('images/avatar.jpg') }}" alt="Avatar JJA DEV"
                        class="img-fluid rounded-circle shadow-lg avatar-img">
                </div>
            </div>
            <div class="col-lg-8 col-md-7">
                <div class="bio-content">
                    <h2 class="display-5 fw-bold text-white mb-4">Bienvenue sur JJA DEV</h2>
                    <p class="lead text-white mb-4">
                        Un laboratoire de développement personnel et un environnement CRM expérimental.
                        Explorez mes projets, expériences et perspectives en développement logiciel.
                    </p>
                </div>
            </div>
        </div>
        <div class="row align-items-center g-4">
            <div class="col-md-12">
                <h3 class="fw-bold text-white mb-3">Philosophy</h3>
                <p class="text-white mb-0">
                    Chez JJA DEV, je crois en l'apprentissage continu, l'expérimentation et le dépassement
                    des limites de ce qui est possible en développement logiciel. Ce laboratoire est un espace
                    pour explorer de nouvelles technologies, construire des solutions innovantes et partager
                    des connaissances avec la communauté.
                </p>
            </div>
        </div>
    </div>
</section>
<!-- Section Stack -->
