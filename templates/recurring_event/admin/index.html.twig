{% extends './admin/base.html.twig' %}
{% set menuActive = 'calendar' %}
{% block title %}{{parent()}} - {{'recurring_event.title'|trans({}, 'calendar')}} {% endblock %}
{% block javascripts %}
    {{ parent() }}
{% endblock %}
{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_adm_accueil') }}">{{'admin.title'|trans({}, 'admin')}}</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_appointment_admin_index')}}">{{'appointment.title'|trans({}, 'calendar')}}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{'recurring_event.title'|trans({}, 'calendar')}}</li>
{% endblock %}
{% block body %}
<div class="row">
    <div class="col-md-6">
        <div class="card card-primary shadow">
            <div class="card-body">
                {{ form_start(form) }}
                {{ form_row(form) }}
                {{ form_rest(form)}}
                {{ form_end(form) }}
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-primary shadow">
            <div class="card-body" {{ react_component('Calendar', {'path': path('app_recurring_event_admin_api_index')}) }}></div>
        </div>
    </div>
</div>
{% endblock %}