{% extends './admin/base.html.twig' %}

{% block title %}Appointment{% endblock %}
{% set menuActive = 'appoitment' %}
{% block body %}
<div class="row">
    <div class="col-md-12">
        <div class="card shadow">
            <div class="card-body">
                        <h1>Appointment</h1>

                <table class="table">
                    <tbody>
                        <tr>
                            <th>Id</th>
                            <td>{{ appointment.id }}</td>
                        </tr>
                        <tr>
                            <th>UserEmail</th>
                            <td>{{ appointment.userEmail }}</td>
                        </tr>
                        <tr>
                            <th>Date</th>
                            <td>{{ appointment.date ? appointment.date|date('Y-m-d') : '' }}</td>
                        </tr>
                        <tr>
                            <th>Time</th>
                            <td>{{ appointment.time ? appointment.time|date('H:i:s') : '' }}</td>
                        </tr>
                        <tr>
                            <th>Type</th>
                            <td>{{ appointment.type }}</td>
                        </tr>
                        <tr>
                            <th>FirstName</th>
                            <td>{{ appointment.firstName }}</td>
                        </tr>
                        <tr>
                            <th>LastName</th>
                            <td>{{ appointment.lastName }}</td>
                        </tr>
                        <tr>
                            <th>MeetingMode</th>
                            <td>{{ appointment.meetingMode }}</td>
                        </tr>
                        <tr>
                            <th>Phone</th>
                            <td>{{ appointment.phone }}</td>
                        </tr>
                        <tr>
                            <th>Company</th>
                            <td>{{ appointment.company }}</td>
                        </tr>
                        <tr>
                            <th>Notes</th>
                            <td>{{ appointment.notes }}</td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>{{ appointment.status }}</td>
                        </tr>
                        <tr>
                            <th>Location</th>
                            <td>{{ appointment.location }}</td>
                        </tr>
                        <tr>
                            <th>ReminderSent</th>
                            <td>{{ appointment.reminderSent }}</td>
                        </tr>
                        <tr>
                            <th>Created_at</th>
                            <td>{{ appointment.createdAt ? appointment.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                        </tr>
                        <tr>
                            <th>Updated_at</th>
                            <td>{{ appointment.updatedAt ? appointment.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                        </tr>
                    </tbody>
                </table>

                <a href="{{ path('app_appointment_admin_index') }}">back to list</a>

                <a href="{{ path('app_appointment_admin_edit', {'id': appointment.id}) }}">edit</a>

                {{ include('appointment/admin/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
