# Copier ce fichier vers .env.local et remplir les valeurs

# OpenAI Configuration (optionnel - pour fonctionnalités IA)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here

# Base de données locale (Docker)
DATABASE_URL=mysql://JJA_DEV:PASSWORD@127.0.0.1:3306/JJA_DEV

# Environnement de développement
APP_ENV=dev
APP_DEBUG=true

# Mailer local (Mailcatcher ou SMTP de test)
MAILER_DSN=smtp://127.0.0.1:1025

# Clé secrète pour Symfony (générer une nouvelle)
APP_SECRET=your_app_secret_here
