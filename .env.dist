# =============================================================================
# CONFIGURATION D'ENVIRONNEMENT JJA_DEV - WINDOWS
# =============================================================================
#
# Ce fichier template (.env.dist) doit être copié vers .env pour la configuration locale
# 
# IMPORTANT: En développement Windows, seule la base de données MySQL tourne en Docker
# PHP, npm et les commandes Symfony sont exécutées localement
#
# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration
#
# =============================================================================
# INSTRUCTIONS WINDOWS:
# =============================================================================
# 1. Copiez ce fichier vers .env : copy .env.dist .env
# 2. Éditez .env avec vos valeurs locales
# 3. Assurez-vous que MySQL tourne en Docker : docker-compose up mysql -d
# 4. Vérifiez votre configuration PHP locale (pdo_mysql activé)
# 5. Utilisez 'symfony console' pour toutes les commandes de développement
# =============================================================================

###> symfony/framework-bundle ###
# Environnement de développement
APP_ENV=dev
# IMPORTANT: Changez cette clé secrète en production !
# Générez une nouvelle clé avec : symfony console secrets:generate-keys
APP_SECRET=your-secret-key-here-change-me-in-production
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# =============================================================================
# BASE DE DONNÉES - CONFIGURATION WINDOWS
# =============================================================================
# MySQL tourne en Docker, PHP connecte depuis l'host Windows
# Port 3306 exposé sur localhost depuis le conteneur Docker
#
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# ÉTAPES DE CONFIGURATION:
# 1. Démarrez MySQL en Docker : docker-compose up mysql -d
# 2. Vérifiez que le port 3306 est accessible : netstat -an | findstr :3306
# 3. Adaptez les valeurs ci-dessous selon votre configuration Docker
#
# Exemples de configuration:
#DATABASE_URL="sqlite:///%kernel.project_dir%/data/data.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
#
# Configuration par défaut JJA_DEV (adaptez le mot de passe !):
DATABASE_URL="mysql://JJA_DEV:CHANGEZ_CE_MOT_DE_PASSE@127.0.0.1:3306/JJA_DEV?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# =============================================================================
# MESSAGERIE ASYNCHRONE
# =============================================================================
# Pour le développement, utilisation de Doctrine (base de données)
# En production, considérez RabbitMQ ou Redis
#
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# =============================================================================
# CONFIGURATION EMAIL - DÉVELOPPEMENT WINDOWS
# =============================================================================
# Pour le développement, utilisez MailHog ou un serveur SMTP local
# MailHog peut être démarré en Docker : docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog
# Interface web accessible sur : http://localhost:8025
#
# Configuration pour MailHog (recommandé en développement):
MAILER_DSN=smtp://127.0.0.1:1025
#
# Alternatives:
# MAILER_DSN=null://null  # Désactive l'envoi d'emails
# MAILER_DSN=smtp://localhost:587  # Serveur SMTP local
###< symfony/mailer ###

###> nelmio/cors-bundle ###
# =============================================================================
# CONFIGURATION CORS - DÉVELOPPEMENT WINDOWS
# =============================================================================
# Autorise les requêtes depuis localhost et 127.0.0.1 avec n'importe quel port
# Adaptez selon vos besoins (ex: ajout de votre IP locale)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> knplabs/github-api ###
# =============================================================================
# INTÉGRATION GITHUB (OPTIONNEL)
# =============================================================================
# Nécessaire uniquement si vous utilisez l'API GitHub dans l'application
# Créez un token personnel sur : https://github.com/settings/tokens
#
GITHUB_AUTH_METHOD=AUTH_ACCESS_TOKEN
GITHUB_USERNAME=your-github-username
GITHUB_SECRET=your-github-personal-access-token
###< knplabs/github-api ###

# =============================================================================
# OPENAI API - POUR FEATURES IA (OPTIONNEL)
# =============================================================================
# Clé API OpenAI pour les fonctionnalités d'intelligence artificielle
# Obtenir une clé sur : https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_ORG_ID=your-openai-org-id-here

# =============================================================================
# VARIABLES SUPPLÉMENTAIRES WINDOWS
# =============================================================================
# Ajoutez ici vos variables d'environnement spécifiques au développement Windows
#
# Exemples:
# WINDOWS_TEMP_DIR=C:\temp
# LOCAL_PHP_PATH=C:\php\php.exe
# NODE_PATH=C:\Program Files\nodejs
